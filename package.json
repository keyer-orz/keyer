{
  "name": "keyer",
  "version": "1.0.0",
  "description": "快捷键呼出命令面板，快捷执行命令",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:extensions && tsc && vite build && electron-builder",
    "build:extensions": "node tools/build-extensions.js",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build:extensions && vite build && electron-builder",
    "electron:build:app": "npm run build:extensions && vite build && electron-builder --mac --dir"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "keyer"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "electron": "^27.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "keyerext": "file:packages/keyerext",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "build": {
    "appId": "com.keyer.app",
    "productName": "Keyer",
    "mac": {
      "category": "public.app-category.productivity",
      "electronLanguages": ["en", "zh_CN"]
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "extensions",
        "to": "extensions",
        "filter": [
          "*/dist/**/*",
          "*/package.json"
        ]
      },
      {
        "from": "scripts",
        "to": "scripts"
      }
    ],
    "directories": {
      "output": "release"
    }
  }
}