{
  "name": "keyer",
  "version": "1.0.0",
  "description": "快捷键呼出命令面板，快捷执行命令",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:extensions": "node tools/build-extensions.js",
    "preview": "vite preview",
    "electron:dev": "concurrently -n keyerext,vite -c cyan,green,yellow \"npm run watch:keyerext\" \"vite\"",
    "pkg": "vite build && electron-builder --mac --dir",
    "link:local": "npm uninstall keyerext && cd ../keyerext && npm link && cd ../keyer && npm link keyerext && echo '✓ 已切换到本地 keyerext'",
    "link:github": "npm uninstall keyerext && npm install keyerext@github:keyer-orz/keyerext && echo '✓ 已切换到 GitHub keyerext'"
  },
  "keywords": [
    "electron",
    "react",
    "typescript",
    "keyer"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^20.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.2.2",
    "electron": "^27.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "wait-on": "^7.0.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "electron-store": "^11.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^5.5.0"
  },
  "build": {
    "appId": "com.keyer.app",
    "productName": "Keyer",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "icon.icns",
      "electronLanguages": [
        "en",
        "zh_CN"
      ]
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "templates",
        "to": "templates",
        "filter": [
          "**/*",
          "!**/dist",
          "!**/dist/**",
          "!**/node_modules",
          "!**/node_modules/**"
        ]
      }
    ],
    "directories": {
      "output": "release"
    }
  }
}
